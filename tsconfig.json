{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["DOM", "ES2020"],
    "rootDir": "src/ts",
    "outDir": ".",
    "checkJs": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "removeComments": false
  },
  "include": ["src/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
